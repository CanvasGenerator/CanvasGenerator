{
    "outputDirectory": ".",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://*.exacttarget.com https://*.marketingcloudapps.com"
                }
            ]
        },
        {
            "source": "/(.*)\\.(js|mjs|css|json|html)",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
            ]
        },
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/cron",
            "destination": "/api/cron"
        },
        {
            "source": "/preview/:name",
            "destination": "/api/router?path=/preview/:name"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/router?path=/api/$1"
        },
        {
            "source": "/:path((?!api/|preview/|.*\\.).+)",
            "destination": "/api/router?path=/:path"
        }
    ]
}
