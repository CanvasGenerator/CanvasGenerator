# Runtime
PORT=8000

# URL publique du site (sans slash final). Sert à transformer les chemins d'assets
# relatifs (logos header/footer "assets/…") en URLs absolues avant publication SFMC,
# pour qu'ils s'affichent correctement dans les CloudPages.
SITE_URL=https://your-site-url.com

# Supabase REST API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# Server-side only. Required for migrations and backend writes when RLS/grants block anon writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini AI
GEMINI_API_KEY=
GEMINI_API_KEY_TRANSLATION=

# Salesforce Marketing Cloud
SFMC_SUBDOMAIN=
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_ACCOUNT_ID=
SFMC_CATEGORY_ID=
SFMC_CATEGORY_NAME=
SFMC_ASSET_TYPE_ID=205
SFMC_ASSET_TYPE_NAME=webpage
SFMC_DE_CATEGORY_ID=
